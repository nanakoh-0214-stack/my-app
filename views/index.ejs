<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>ユーザー一覧</title></head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <!-- 年齢があれば表示し、なければ「未設定」と出すようにするぞ -->
      <li><%= user.name %> - <%= user.age ? user.age : '未設定' %></li>
    <% }) %>
  </ul>
  <h2>ユーザー追加</h2>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="ユーザー名を入力" required>
    <!-- 年齢を入力する欄を追加じゃ。数値のみ受け付けるぞ -->
    <input type="number" name="age" placeholder="年齢を入力" required>
    <button type="submit">追加</button>
  </form>
</body>
</html>
