<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title><%= group.name %></title>
</head>
<body>

<h1><%= group.name %></h1>

<h2>メンバー一覧</h2>
<ul>
<% group.members.forEach(member => { %>
  <li>
    <%= member.name %>
    <form
      action="/members/<%= member.id %>/delete"
      method="post"
      style="display:inline;"
      onsubmit="return confirm('このメンバーを削除しますか？このメンバーの支払いも削除されます。');"
    >
      <button type="submit">
        削除
      </button>
    </form>
  </li>
<% }) %>
</ul>

<h2>メンバー追加</h2>
<form action="/groups/<%= group.id %>/members" method="post">
  <input
    type="text"
    name="name"
    placeholder="メンバー名"
    required
  >
  <button type="submit">
    追加
  </button>
</form>

<h2>支払い一覧</h2>
<ul>
<% group.expenses.forEach(expense => { %>
<li>
<strong><%= expense.description %></strong>
<br>
<%= expense.amount %>円
<br>
支払者：
<%= expense.payer.name %>
<br>
参加者：
<%= expense.shares.map(share => share.member.name).join("、") %>
<br>
<%= expense.paidAt.toLocaleString("ja-JP") %>
<br><br>
<form
  action="/expenses/<%= expense.id %>/delete"
  method="post"
  style="display:inline;"
>
  <button
    type="submit"
    onclick="return confirm('この支払いを削除しますか？')"
  >
    削除
  </button>
</form>
</li>
<hr>
<% }) %>
</ul>

<h2>精算状況</h2>
<p>支払い合計：<%= totalAmount %> 円</p>
<p>メンバー数：<%= memberCount %> 人</p>
<table border="1">
<tr>
  <th>名前</th>
  <th>支払額</th>
  <th>差額</th>
</tr>
<% settlements.forEach(member => { %>
<tr>
<td><%= member.name %></td>
<td><%= member.paidAmount %> 円</td>
<td>
<%= member.balance %> 円
</td>
</tr>
<% }) %>
</table>

<h2>精算結果</h2>
<ul>
<% transfers.forEach(transfer => { %>
<li>
<strong><%= transfer.from %></strong>
→
<strong><%= transfer.to %></strong>
：
<%= transfer.amount %> 円
</li>
<% }) %>
</ul>

<h2>支払い追加</h2>
<form action="/groups/<%= group.id %>/expenses" method="post">
  <label>支払者</label>
  <select name="payerId">
    <% group.members.forEach(member => { %>
      <option value="<%= member.id %>">
        <%= member.name %>
      </option>
    <% }) %>
  </select>
  <br><br>
  <label>金額</label>
  <input
    type="number"
    name="amount"
    required
  >
  <br><br>
  <label>内容</label>
  <input
    type="text"
    name="description"
    required
  >
  <br><br>
  <label>日時</label>
  <input
    type="datetime-local"
    name="paidAt"
    required
  >
  <br><br>
  <label>参加者</label>
  <br>
  <% group.members.forEach(member => { %>
    <label>
      <input
        type="checkbox"
        name="participantIds"
        value="<%= member.id %>"
        checked
      >
      <%= member.name %>
    </label>
    <br>
  <% }) %>
  <br>
  <button>登録</button>
</form>

<form
  action="/groups/<%= group.id %>/delete"
  method="post"
  onsubmit="return confirm('このグループを削除しますか？メンバー・支払いもすべて削除されます。');"
>
  <button type="submit">
    グループを削除
  </button>
</form>

<br><br>

<a href="/">← グループ一覧へ戻る</a>

</body>
</html>