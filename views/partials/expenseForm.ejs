<h2><%= isEdit ? "支払い編集" : "支払い追加" %></h2>

<form action="<%= formAction %>" method="post">

  <div class="form-group">
    <label for="payerId">支払者</label>

    <select id="payerId" name="payerId">
      <% group.members.forEach(member => { %>

        <option
          value="<%= member.id %>"
          <%= expense && member.id === expense.payerId ? "selected" : "" %>>
          <%= member.name %>
        </option>

      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label for="amount">金額（円）</label>

    <input
      id="amount"
      type="number"
      name="amount"
      value="<%= expense ? expense.amount : '' %>"
      placeholder="例：3000"
      required
    >
  </div>

  <div class="form-group">
    <label for="description">内容</label>

    <input
      id="description"
      type="text"
      name="description"
      value="<%= expense ? expense.description : '' %>"
      placeholder="例：居酒屋"
      required
    >
  </div>

  <div class="form-group">
    <label for="paidAt">日時</label>

    <input
      id="paidAt"
      type="datetime-local"
      name="paidAt"
      value="<%= expense ? expense.paidAtLocal : '' %>"
      required
    >
  </div>

  <div class="form-group">
    <label>割り勘方法</label>

    <div class="radio-group">

      <label>
        <input
          type="radio"
          name="useWeight"
          value="false"
          <%= !expense || !expense.useWeight ? "checked" : "" %>
          onchange="toggleWeight()"
        >
        均等割り
      </label>

      <label>
        <input
          type="radio"
          name="useWeight"
          value="true"
          <%= expense && expense.useWeight ? "checked" : "" %>
          onchange="toggleWeight()"
        >
        傾斜あり
      </label>

    </div>
  </div>

  <div class="form-group">

    <label>参加者</label>

    <div class="participant-grid">

      <% group.members.forEach(member => { %>

        <% const share = expense
          ? expense.shares.find(s => s.memberId === member.id)
          : null;
        %>

        <div class="participant-item">

          <label class="participant-checkbox">

            <input
              type="checkbox"
              name="participantIds"
              value="<%= member.id %>"
              <%= !expense || share ? "checked" : "" %>
            >

            <span><%= member.name %></span>

          </label>

          <div class="weight-section <%= expense && expense.useWeight ? "" : "hidden" %>">

            <input
              type="number"
              name="weights[<%= member.id %>]"
              value="<%= share ? share.weight : 1 %>"
              min="0.1"
              step="0.1"
              class="weight-input"
              <%= expense && expense.useWeight ? "" : "disabled" %>
            >

          </div>

        </div>

      <% }) %>

    </div>

  </div>

  <button
    type="submit"
    class="submit-btn"
  >
    <%= isEdit ? "更新" : "登録" %>
  </button>

</form>

<script src="/js/group.js"></script>