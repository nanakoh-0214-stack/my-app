<details class="member-section">
  <summary>
    メンバー一覧（<%= group.members.length %>人）
  </summary>

  <ul class="member-list">
    <% group.members.forEach(member => { %>
      <li class="member-item">
        <span class="member-name">
          <%= member.name %>
        </span>

        <form
          action="/members/<%= member.id %>/delete"
          method="post"
          class="inline-form"
          onsubmit="return confirm('このメンバーを削除しますか？このメンバーの支払いも削除されます。');"
        >
          <button type="submit" class="delete-btn">
            削除
          </button>
        </form>
      </li>
    <% }) %>
  </ul>
</details>

<h2>メンバー追加</h2>
<form action="/groups/<%= group.id %>/members" method="post">
  <input
    type="text"
    name="name"
    placeholder="メンバー名"
    required
  >
  <button type="submit">追加</button>
</form>