<h2>精算状況</h2>

<div class="settlement-summary">
  <div class="summary-card">
    <span class="summary-label">支払い合計</span>
    <span class="summary-value">
      ¥<%= totalAmount.toLocaleString() %>
    </span>
  </div>

  <div class="summary-card">
    <span class="summary-label">メンバー数</span>
    <span class="summary-value">
      <%= memberCount %> 人
    </span>
  </div>

</div>

<table class="settlement-table">
  <thead>
    <tr>
      <th>名前</th>
      <th>支払額</th>
      <th>差額</th>
    </tr>
  </thead>

  <tbody>
    <% settlements.forEach(member => { %>
      <tr>
        <td>
          <%= member.name %>
        </td>
        <td>
          ¥<%= member.paidAmount.toLocaleString() %>
        </td>
        <td
          class="
            <%= member.balance > 0
                ? 'plus'
                : member.balance < 0
                  ? 'minus'
                  : 'zero' %>
          "
        >
          <% if(member.balance > 0){ %>
            +¥<%= member.balance.toLocaleString() %>
          <% } else { %>
            ¥<%= member.balance.toLocaleString() %>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<h2>精算結果</h2>

<div class="transfer-list">
  <% transfers.forEach(transfer => { %>
    <div class="transfer-card">
      <div class="transfer-icon"> 💸 </div>
      <div class="transfer-members">
        <span class="transfer-from"> <%= transfer.from %> </span>
        <span class="transfer-arrow"> → </span>
        <span class="transfer-to"> <%= transfer.to %> </span>
      </div>
      <div class="transfer-amount">
        ¥<%= transfer.amount.toLocaleString() %>
      </div>
    </div>
    <% }) %>
</div>