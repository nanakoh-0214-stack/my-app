<details class="expense-section">

  <summary>
    支払い一覧（<%= group.expenses.length %>件）
  </summary>

  <div class="expense-list">
    <% group.expenses.forEach(expense => { %>

      <div class="expense-card">

        <div class="expense-header">
          <span class="expense-title">
            <%= expense.description %>
          </span>

          <span class="expense-amount">
            ¥<%= expense.amount.toLocaleString() %>
          </span>
        </div>

        <div class="expense-info">
          <strong>支払者：</strong>
          <%= expense.payer.name %>
        </div>

        <div class="expense-info">
          <strong>参加者：</strong>
          <%= expense.shares
                .map(share => share.member.name)
                .join("、") %>
        </div>

        <div class="expense-info">
          <strong>日時：</strong>
          <%= expense.paidAt.toLocaleString("ja-JP") %>
        </div>

        <div class="expense-actions">

          <a
            href="/expenses/<%= expense.id %>/edit"
            class="edit-btn"
          >
            編集
          </a>

          <form
            action="/expenses/<%= expense.id %>/delete"
            method="post"
            class="expense-delete-form"
            onsubmit="return confirm('この支払いを削除しますか？');"
          >
            <button
              type="submit"
              class="delete-btn"
            >
              削除
            </button>
          </form>

        </div>

      </div>

    <% }) %>
  </div>

</details>